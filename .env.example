# App runtime
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Music library behavior
MUSIC_SOURCE_ROOTS=/path/to/music/library1,/path/to/music/library2
TAGGED_OUTPUT_ROOT=/path/to/tagged-output
CLEAR_METADATA=false

# MusicBrainz client
MUSICBRAINZ_USER_AGENT=pytagrelease/0.1.0 (contact: you@example.com)
MUSICBRAINZ_TIMEOUT_SECONDS=10
MUSICBRAINZ_RATE_LIMIT_PER_SECOND=1